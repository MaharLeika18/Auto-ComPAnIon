<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="1080" prefWidth="1920" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autocompanion.pos.fx.DashboardController">

    <!-- BACKGROUND -->
    <ImageView fitHeight="1080" fitWidth="1920">
        <image>
            <Image url="@../Assets/POS(BG).png" />
        </image>
    </ImageView>

    <!-- NAV BUTTONS (invisible hit areas – untouched) -->
<Button fx:id="inventoryButton" layoutX="717.0" layoutY="76.0" mnemonicParsing="false" opacity="0.0" prefHeight="92.0" prefWidth="309.0" text="INV" onAction="#openInventory" />
<Button fx:id="paiButton" layoutX="1063.0" layoutY="72.0" mnemonicParsing="false" opacity="0.0" prefHeight="92.0" prefWidth="341.0" text="PAI" onAction="#openPai" />
  
    <!-- SEARCH FIELD -->
    <TextField fx:id="searchField" layoutX="648.0" layoutY="223.0" prefHeight="65.0" prefWidth="421.0" style="-fx-background-radius: 50; -fx-border-width: 0;" text="Search">
        <font><Font name="Montserrat Regular" size="18.0" /></font>
    </TextField>

    <!-- RECEIPT / SUMMARY PANEL -->
    <Pane layoutX="1322.0" layoutY="288.0" prefHeight="707.0" prefWidth="485.0">
        <children>

            <!-- divider under header block -->
            <Line endX="365.0" layoutX="110.0" layoutY="170.0" startX="-100.0" stroke="#bdbdbd" />

            <!-- Labels (left column) -->
            <Label layoutX="12.0" layoutY="14.0" prefHeight="58.0" prefWidth="192.0" text="Receipt No." textFill="#649e8f">
                <font><Font name="Montserrat SemiBold" size="25.0" /></font>
            </Label>
            <Label layoutX="12.0" layoutY="54.0" prefHeight="58.0" prefWidth="192.0" text="Date" textFill="#649e8f">
                <font><Font name="Montserrat SemiBold" size="25.0" /></font>
            </Label>
            <Label layoutX="12.0" layoutY="97.0" prefHeight="58.0" prefWidth="192.0" text="Time" textFill="#649e8f">
                <font><Font name="Montserrat SemiBold" size="25.0" /></font>
            </Label>

            <!--
                RECEIPT NUMBER  – editable TextField so cashier can override.
                Positioned at the same x/y as the old dummy Label was.
            -->
            <TextField fx:id="receiptNoField" layoutX="220.0" layoutY="25.0" prefHeight="32.0" prefWidth="250.0" style="-fx-background-color: transparent;                               -fx-border-width: 0 0 1 0;                               -fx-border-color: #bdbdbd;                               -fx-text-fill: #1c4f43;                               -fx-font-family: 'Montserrat Regular';                               -fx-font-size: 18;" />

            <!-- Date label (auto-updated by controller) -->
            <Label fx:id="datelb" contentDisplay="CENTER" layoutX="217.0" layoutY="70.0" prefHeight="26.0" prefWidth="256.0" textFill="#1c4f43">
                <font><Font name="Montserrat Regular" size="20.0" /></font>
            </Label>

            <!-- Time label (live clock) -->
            <Label fx:id="timelb" contentDisplay="CENTER" layoutX="217.0" layoutY="113.0" prefHeight="26.0" prefWidth="256.0" textFill="#1c4f43">
                <font><Font name="Montserrat Regular" size="20.0" /></font>
            </Label>

            <!--
                CART SCROLL AREA
                Sits between the header divider and the summary box.
                Height = 415 - 175 = 240 px of usable space.
            -->
            <ScrollPane fx:id="cartScrollPane" hbarPolicy="NEVER" layoutX="-14.0" layoutY="178.0" prefHeight="228.0" prefWidth="514.0" style="-fx-background: transparent; -fx-background-color: transparent;" />

            <!-- SUMMARY BOX -->
            <Pane layoutX="-16.0" layoutY="415.0" prefHeight="222.0" prefWidth="514.0" style="-fx-background-color: #EEF4ED; -fx-background-radius: 50;">
                <children>

                    <!-- Row labels -->
                    <Label layoutX="42.0" layoutY="14.0" prefHeight="38.0" prefWidth="192.0" text="Item Quantity" textFill="#649e8f">
                        <font><Font name="Montserrat SemiBold" size="22.0" /></font>
                    </Label>
                    <Label layoutX="42.0" layoutY="53.0" prefHeight="38.0" prefWidth="192.0" text="Subtotal" textFill="#649e8f">
                        <font><Font name="Montserrat SemiBold" size="22.0" /></font>
                    </Label>
                    <Label layoutX="42.0" layoutY="97.0" prefHeight="38.0" prefWidth="192.0" text="Discount" textFill="#649e8f">
                        <font><Font name="Montserrat SemiBold" size="22.0" /></font>
                    </Label>

                    <Line endX="365.0" layoutX="107.0" layoutY="148.0" startX="-100.0" stroke="#bdbdbd" />

                    <Label layoutX="42.0" layoutY="156.0" prefHeight="40.0" prefWidth="192.0" text="Total" textFill="#649e8f">
                        <font><Font name="Montserrat SemiBold" size="25.0" /></font>
                    </Label>

                    <!-- Value labels (right column) – wired to controller -->
                    <Label fx:id="itemQuantityLabel" layoutX="386.0" layoutY="18.0" text="0" textFill="#1c4f43">
                        <font><Font name="Montserrat Regular" size="20.0" /></font>
                    </Label>
                    <Label fx:id="subtotalLabel" layoutX="300.0" layoutY="57.0" text="₱0.00" textFill="#1c4f43">
                        <font><Font name="Montserrat Regular" size="20.0" /></font>
                    </Label>

                   <TextField fx:id="discountField" layoutX="300.0" layoutY="97.0" prefHeight="38.0" prefWidth="150.0" 
    style="-fx-background-color: transparent; 
           -fx-border-width: 0 0 1 0; 
           -fx-border-color: #bdbdbd; 
           -fx-text-fill: #1c4f43; 
           -fx-font-family: 'Montserrat Regular'; 
           -fx-font-size: 20;"
    text="₱0.00" />

                    <Label fx:id="totalLabel" layoutX="300.0" layoutY="160.0" text="₱0.00" textFill="#1c4f43">
                        <font><Font name="Montserrat SemiBold" size="22.0" /></font>
                    </Label>

                </children>
            </Pane>

            <!-- PROCESS PAYMENT BUTTON -->
            <Button fx:id="processPaymentBtn" layoutX="-1.0" layoutY="651.0" mnemonicParsing="false" onAction="#processPayment" prefHeight="50.0" prefWidth="485.0" style="-fx-background-color: #1FFFCB;                            -fx-background-radius: 70;                            -fx-cursor: hand;" text="Process Payment" textFill="#1c4f43">
                <font><Font name="Orbitron Regular" size="20.0" /></font>
            </Button>

        </children>
    </Pane>

    <!-- PRODUCT SCROLL PANE (left panel) -->
    <ScrollPane fx:id="productScrollPane" hbarPolicy="NEVER" layoutX="102.0" layoutY="357.0" prefHeight="641.0" prefWidth="1145.0" style="-fx-background: transparent; -fx-background-color: transparent;" />

</AnchorPane>
