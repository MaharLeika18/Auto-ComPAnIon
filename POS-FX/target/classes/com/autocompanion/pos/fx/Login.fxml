            <Image url="@../img/loginasset2.png" />
         </image>
      </ImageView>
      
      <!-- Username Field -->
      <TextField fx:id="txtUsername" layoutX="379.0" layoutY="325.0" prefHeight="45.0" prefWidth="217.0" promptText="Enter Username" style="-fx-background-radius: 70; -fx-background-color: #b3b3b3; -fx-font-family: Montserrat;">
